##############################################################################
#                                                                            #
#   Order & Payment Management API — Environment Configuration               #
#                                                                            #
#   Copy this file to ".env" and fill in the values for your environment.    #
#   Run:  cp .env.example .env && php artisan key:generate && php artisan jwt:secret  #
#                                                                            #
##############################################################################

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME="Order & Payment API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQLite works out of the box. For MySQL / PostgreSQL, set the DB_* values below
# and remove (or ignore) the sqlite line.
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=order_payment_api
# DB_USERNAME=root
# DB_PASSWORD=

# ---------------------------------------------------------------------------
# Sessions / Cache / Queue / Filesystem
# ---------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Mail
# ---------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ---------------------------------------------------------------------------
# AWS (optional)
# ---------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ---------------------------------------------------------------------------
# JWT Authentication (tymon/jwt-auth)
# ---------------------------------------------------------------------------
# Generate with: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60
JWT_REFRESH_TTL=20160
JWT_LEEWAY=0

# ---------------------------------------------------------------------------
# Payment Gateways
# ---------------------------------------------------------------------------
# Run the gateways in simulation mode (no real credentials needed).
# Set to false in production to require the real credentials below.
PAYMENT_SIMULATE=true

# Success rates used only in simulation mode (percentage 0-100).
PAYPAL_SUCCESS_RATE=90
CREDIT_CARD_SUCCESS_RATE=85
STRIPE_SUCCESS_RATE=95

# Real provider credentials — required when PAYMENT_SIMULATE=false.
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=sandbox

CREDIT_CARD_PROVIDER=
CREDIT_CARD_API_KEY=

# Future gateway placeholders
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Frontend (Vite)
# ---------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
